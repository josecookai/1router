{
  "name": "1router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "openapi:validate": "node scripts/openapi/validate.mjs",
    "openapi:generate": "node scripts/openapi/generate.mjs",
    "openapi:check": "npm run openapi:validate && npm run openapi:generate && git diff --exit-code -- src/generated/api-types.ts src/generated/api-mocks.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "openapi-typescript": "^7.6.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "yaml": "^2.7.0"
  }
}
